# APT Early Detection — environment variables template
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── API settings ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ── Logging ─────────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Model paths (override defaults if models are mounted elsewhere) ───────────────
MODELS_DIR=./models

# ── Dashboard ────────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501
# API base URL for dashboard (used when running in Docker)
API_BASE_URL=http://api:8000

# ── Alert thresholds (realtime detector) ─────────────────────────────────────────
# Minimum confidence to trigger an alert (0.0 – 1.0)
ALERT_THRESHOLD=0.7
