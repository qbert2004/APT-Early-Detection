# APT Early Detection — environment variables template
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── API settings ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ── Logging ─────────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Model paths (override defaults if models are mounted elsewhere) ───────────────
MODELS_DIR=./models

# ── Dashboard ────────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501
# API base URL for dashboard (used when running in Docker)
API_BASE_URL=http://api:8000

# ── Alert thresholds (realtime detector) ─────────────────────────────────────────
# Minimum confidence to trigger an alert (0.0 – 1.0)
ALERT_THRESHOLD=0.7

# ── Telegram notifications ────────────────────────────────────────────────────────
# 1. Create bot via @BotFather → copy token
# 2. Send any message to bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → copy id from "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Threat Intelligence (AbuseIPDB) ──────────────────────────────────────────────
# Free tier: 1000 IP checks/day — enough for demo and low-volume deployments
# Register at https://www.abuseipdb.com → API → Create Key
ABUSEIPDB_API_KEY=
